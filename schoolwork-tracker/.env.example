# Comma-separated list of student identifiers (lowercase, no spaces).
# Each identifier maps to a set of ARGO_<NAME>_* variables below.
ARGO_STUDENTS=marco,giulia

# Credentials for each student's Argo didUP account.
# School code is the "codice scuola" (e.g. SS12345), username/password are the
# didUP Famiglia credentials (native Argo accounts, not SPID).
ARGO_MARCO_SCHOOL_CODE=SS12345
ARGO_MARCO_USERNAME=marco.username
ARGO_MARCO_PASSWORD=secret

ARGO_GIULIA_SCHOOL_CODE=SS12345
ARGO_GIULIA_USERNAME=giulia.username
ARGO_GIULIA_PASSWORD=secret

# When one parent account covers multiple children, the same credentials go in
# each student's block and STUDENT_NAME (case-insensitive substring of the
# child's full name as registered in Argo) picks the right child. Without it,
# every student would silently get the first child's data.
# ARGO_MARCO_STUDENT_NAME=marco
# ARGO_GIULIA_STUDENT_NAME=giulia

# Optional: minutes between background re-syncs of the Argo dashboard (default 10)
# ARGO_SYNC_TTL_MINUTES=10

# Optional: replace student and teacher names with initials ("Rossi Maria" →
# "R.M.") in everything the tools return, so real names never enter the chat.
# Name fields are always reduced to initials; free text (homework, comments,
# notices) is scrubbed against the names known from the register, best-effort.
# For full anonymity also pick neutral identifiers in ARGO_STUDENTS (e.g.
# "kid1") — those appear verbatim as the `student` tool parameter.
# ARGO_REDACT_NAMES=true
